<%- include('partials/header') %>

<h2 class="mb-4">친구 관리</h2>

<!-- 친구 추가 폼 -->
<div class="form-card mb-4" style="max-width: 100%;">
  <h5 class="mb-3">친구 추가</h5>
  <form action="/users/friends/add" method="POST" class="d-flex gap-2">
    <input type="text" name="friendId" class="form-control" placeholder="추가할 사용자 아이디 입력">
    <button class="btn btn-primary" style="white-space:nowrap;">추가</button>
  </form>
  <% if (error) { %>
    <div class="alert alert-danger mt-2 mb-0 py-2"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success mt-2 mb-0 py-2"><%= success %></div>
  <% } %>
</div>

<!-- 친구 목록 -->
<h5>친구 목록 <span class="badge bg-secondary"><%= friends.length %></span></h5>

<% if (friends.length === 0) { %>
  <p class="text-muted">아직 친구가 없습니다. 친구를 추가해보세요.</p>
<% } else { %>
  <ul class="list-group">
    <% friends.forEach(f => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <strong>👤 <%= f.userId %></strong>
          <small class="text-muted ms-2">추가일: <%= new Date(f.addedAt).toLocaleDateString('ko-KR') %></small>
        </div>
        <div class="d-flex gap-2">
          <a href="/items?seller=<%= f.userId %>" class="btn btn-sm btn-outline-primary">상품 보기</a>
          <form action="/users/friends/remove" method="POST">
            <input type="hidden" name="friendId" value="<%= f.userId %>">
            <button class="btn btn-sm btn-danger">삭제</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('partials/footer') %>