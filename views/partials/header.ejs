<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>MyMarket</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<% if (typeof hideNav === 'undefined' || !hideNav) { %>
<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/items">MyMarket</a>

    <div>
      <% if (user) { %>
        <a href="/items/write" class="btn btn-sm btn-success me-2">상품 등록</a>
        <a href="/users/friends" class="btn btn-sm btn-info me-2">친구</a>
        <span class="text-white me-3">👤 <%= user.userId %></span>
        <a href="/users/logout" class="btn btn-sm btn-outline-light">로그아웃</a>
      <% } else { %>
        <a href="/users/login" class="btn btn-sm btn-outline-light me-2">로그인</a>
        <a href="/users/register" class="btn btn-sm btn-outline-light">회원가입</a>
      <% } %>
    </div>
  </div>
</nav>
<% } %>

<div class="container mt-4">