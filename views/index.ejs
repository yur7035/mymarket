<%- include('partials/header') %>

<!-- 친구 상품 섹션 (로그인 + 친구 상품이 있을 때만 표시) -->
<% if (user && friendItems && friendItems.length > 0) { %>
<div class="mb-5">
  <h4 class="mb-3">친구의 최신 판매 상품</h4>
  <div class="row">
    <% friendItems.forEach(item => { %>
      <div class="col-md-4">
        <div class="card mb-3 shadow-sm border-primary">
          <% if (item.image) { %>
            <img src="<%= item.image %>" class="card-img-top" style="height:180px; object-fit:cover;">
          <% } else { %>
            <div class="bg-secondary text-white text-center py-4">이미지 없음</div>
          <% } %>
          <div class="card-body">
            <span class="badge bg-primary mb-1">친구</span>
            <h6 class="card-title"><%= item.title %></h6>
            <p class="card-text mb-1"><%= item.price %>원</p>
            <p class="text-muted small">판매자: <%= item.userId %></p>
            <a href="/items/<%= item._id %>" class="btn btn-sm btn-outline-primary">상세보기</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  <hr>
</div>
<% } %>

<h2 class="mb-4">상품 목록</h2>

<div class="row">
  <% items.forEach(item => { %>
    <div class="col-md-4">
      <div class="card mb-4 shadow-sm">
        <% if (item.image) { %>
          <img src="<%= item.image %>" class="card-img-top" style="height:200px; object-fit:cover;">
        <% } else { %>
          <div class="bg-secondary text-white text-center py-5">이미지 없음</div>
        <% } %>

        <div class="card-body">
          <h5 class="card-title"><%= item.title %></h5>
          <p class="card-text"><%= item.price %>원</p>
          <p class="text-muted small">판매자: <%= item.userId %></p>
          <a href="/items/<%= item._id %>" class="btn btn-primary">상세보기</a>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
