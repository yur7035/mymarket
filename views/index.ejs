<%- include('partials/header') %>

<% if (user && friendItems && friendItems.length > 0) { %>
<div class="mb-5">
  <h4 class="mb-3">친구의 최신 판매 상품</h4>
  <div class="row">
    <% friendItems.forEach(item => { %>
      <div class="col-md-4">
        <div class="card mb-3 border-primary">
          <% if (item.image) { %>
            <img src="<%= item.image %>" class="card-img-top" style="height:140px; object-fit:cover;">
          <% } else { %>
            <div class="bg-secondary text-center py-3">이미지 없음</div>
          <% } %>
          <div class="card-body">
            <p class="card-title-line"><%= item.title %></p>
            <p class="card-price-line"><%= item.price.toLocaleString() %>원</p>
            <div class="card-meta-row mb-2">
              <span class="card-meta-time">판매자: <%= item.userId %></span>
              <span class="card-friend-tag">친구</span>
            </div>
            <a href="/items/<%= item._id %>" class="btn btn-sm btn-outline-primary w-100">상세보기</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  <hr>
</div>
<% } %>

<h2 class="mb-4">상품 목록</h2>

<div class="row">
  <% items.forEach(item => { %>
    <div class="col-md-4">
      <div class="card mb-4">
        <% if (item.image) { %>
          <img src="<%= item.image %>" class="card-img-top" style="aspect-ratio: 1/1; width:100%; object-fit:cover;">
        <% } else { %>
          <div class="bg-secondary text-center py-3">이미지 없음</div>
        <% } %>

        <div class="card-body">
          <p class="card-title-line"><%= item.title %></p>
          <p class="card-price-line"><%= item.price.toLocaleString() %>원</p>
          <div class="card-meta-row mb-2">
            <span class="card-meta-time">판매자: <%= item.userId %></span>
            <span class="card-meta-time"><%= new Date(item.createdAt).toLocaleDateString('ko-KR') %></span>
          </div>
          <a href="/items/<%= item._id %>" class="btn btn-primary w-100">상세보기</a>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>