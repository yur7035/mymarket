<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card">
      <% if (item.image) { %>
        <img src="<%= item.image %>" class="card-img-top detail-image" style="aspect-ratio: auto; max-height:280px; object-fit:cover;">
      <% } else { %>
        <div class="bg-secondary text-center py-5 detail-image" style="border-radius: var(--radius) var(--radius) 0 0;">이미지 없음</div>
      <% } %>

      <div class="card-body p-4">
        <h2 class="detail-title"><%= item.title %></h2>
        <p class="detail-price mb-2"><%= item.price.toLocaleString() %>원</p>
        <p class="detail-meta mb-4">판매자: <%= item.userId %></p>

        <p class="mb-4" style="white-space: pre-line;"><%= item.description %></p>

        <% if (item.document) { %>
            <a href="<%= item.document %>" target="_blank" class="btn btn-info">첨부 문서 보기</a>
            <% if (item.document.toLowerCase().endsWith('.pdf')) { %>
              <div class="mt-3">
                <embed src="<%= item.document %>" type="application/pdf" width="100%" height="500px">
              </div>
            <% } %>
        <% } %>

        <div class="d-flex gap-2 mt-3">
          <a href="/items" class="btn btn-secondary">목록으로</a>

          <% if (user && user.userId === item.userId) { %>
            <a href="/items/edit/<%= item._id %>" class="btn btn-warning">수정</a>
            <form action="/items/delete/<%= item._id %>" method="POST">
              <button class="btn btn-danger">삭제</button>
            </form>
          <% } %>

        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>